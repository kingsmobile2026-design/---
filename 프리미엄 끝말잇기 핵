local SBASE, VCOUNT, TCOUNT = 0xAC00, 21, 28
local NCOUNT, SCOUNT = VCOUNT * TCOUNT, 19 * VCOUNT * TCOUNT
local CHO = {0x3131,0x3132,0x3134,0x3137,0x3138,0x3139,0x3141,0x3142,0x3143,0x3145,0x3146,0x3147,0x3148,0x3149,0x314A,0x314B,0x314C,0x314D,0x314E}
