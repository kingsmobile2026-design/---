local JONG_KEYS = {}
for i = 1, 27 do JONG_KEYS[i] = {JONG[i]} end
JONG_KEYS[3]={0x3131,0x3145}; JONG_KEYS[5]={0x3134,0x3148}; JONG_KEYS[6]={0x3134,0x314E}
JONG_KEYS[9]={0x3139,0x3131}; JONG_KEYS[10]={0x3139,0x3141}; JONG_KEYS[11]={0x3139,0x3142}
