end)

local function updateView(key)
    for _, c in ipairs(scroll:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end

    if key == "" then return end
    local targets = getCompatibleChars(key)
    local uniqueCheck = {}

    for _, w in ipairs(WordDB) do
        for _, target in ipairs(targets) do
            if string.sub(w, 1, string.len(target)) == target then
                if not uniqueCheck[w] then
                    uniqueCheck[w] = true
                    
                    local lbl = Instance.new("TextButton", scroll)
                    lbl.Size = UDim2.new(1, -5, 0, 30)
                    lbl.BackgroundColor3 = Color3.fromRGB(90, 25, 30)
                    lbl.Text = "  🔥 [한방 단어]  " .. w
                    lbl.TextColor3 = Color3.fromRGB(255, 220, 100)
                    lbl.Font = Enum.Font.SourceSansBold
                    lbl.TextSize = 13
                    lbl.TextXAlignment = Enum.TextXAlignment.Left
                    lbl.LayoutOrder = 1
                    Instance.new("UICorner", lbl)

                    lbl.MouseButton1Click:Connect(function()
                        sendWordToGame(w)
                    end)
                end
                break
            end
        end
    end

    for _, target in ipairs(targets) do
        if DICT and DICT[target] then
            for _, w in ipairs(DICT[target]) do
                if not uniqueCheck[w] then
                    uniqueCheck[w] = true
                    
                    local lbl = Instance.new("TextButton", scroll)
                    lbl.Size = UDim2.new(1, -5, 0, 30)
                    lbl.Font = Enum.Font.SourceSansBold
                    lbl.TextSize = 13
                    lbl.TextXAlignment = Enum.TextXAlignment.Left
                    Instance.new("UICorner", lbl)

                    if checkIsKillWord(w) then
                        lbl.BackgroundColor3 = Color3.fromRGB(90, 25, 30)
                        lbl.Text = "  🔥 [한방 단어]  " .. w
                        lbl.TextColor3 = Color3.fromRGB(255, 220, 100)
                        lbl.LayoutOrder = 1
                    else
                        lbl.BackgroundColor3 = Color3.fromRGB(30, 45, 35)
                        lbl.Text = "  🛡️ [루프 방어]  " .. w
                        lbl.TextColor3 = Color3.fromRGB(130, 255, 170)
                        lbl.LayoutOrder = 2
                    end

                    lbl.MouseButton1Click:Connect(function()
                        sendWordToGame(w)
                    end)
                end
            end
        end
    end

    scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 6)
end

