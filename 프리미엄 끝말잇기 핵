local function findGameTextBox()
    local plGui = game:GetService("Players").LocalPlayer:FindFirstChildOfClass("PlayerGui")
    if not plGui then return nil end
    local gg = plGui:FindFirstChild("GameGui")
    local box = gg and gg:FindFirstChild("TriesFrame") and gg.TriesFrame:FindFirstChild("TypeFrame") and gg.TriesFrame.TypeFrame:FindFirstChild("TextBox")
    if box and box:IsA("TextBox") then
        pcall(function()
            box.Visible = _T; box.Active = _T; box.Selectable = _T; box.Interactable = _T
            if box.Parent then box.Parent.Visible = _T end
        end)
        return box
    end
    for _, v in ipairs(plGui:GetDescendants()) do
        if v:IsA("TextBox") then
            if v.Name == "TextBox" or v.Name == "InputText" or (v.Parent and v.Parent.Name == "TypeFrame") then
                pcall(function()
                    v.Visible = _T; v.Active = _T; v.Selectable = _T; v.Interactable = _T
                    if v.Parent then v.Parent.Visible = _T end
                end)
                return v
            end
        end
    end
    return nil
end

local function sendWordToGame(word)
    if word == "" then return end
    local targetBox = findGameTextBox()
    if not targetBox then return end
    local speed = tonumber(speedInputBox.Text) or 400
    pcall(function()
        targetBox.Text = ""
        targetBox:CaptureFocus() 
        if speed <= 0 then
            targetBox.Text = word
        else
            local totalStates = buildTypeStates(word)
            local delayTime = 60 / (speed * 2.5) 
            for _, partialText in ipairs(totalStates) do
                targetBox.Text = partialText
                task.wait(delayTime)
            end
        end
        task.wait(0.01)
        targetBox:ReleaseFocus(_T) 
    end)
end

