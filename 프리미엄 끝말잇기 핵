local CHO_OF, JUNG_OF, JONG_OF = {}, {}, {}
for i, c in ipairs(CHO) do CHO_OF[c] = i - 1 end
for i, c in ipairs(JUNG) do JUNG_OF[c] = i - 1 end
for i = 1, 27 do if #JONG_KEYS[i] == 1 then JONG_OF[JONG_KEYS[i][1]] = i end end

local JONG_COMBINE, JUNG_COMBINE = {}, {}
for i = 1, 27 do local k = JONG_KEYS[i]; if #k == 2 then JONG_COMBINE[JONG_OF[k[1]]*100 + k[2]] = i end end
for i = 0, 20 do local k = JUNG_KEYS[i]; if #k == 2 then JUNG_COMBINE[JUNG_OF[k[1]]*1000 + k[2]] = i end end

local function wordToKeys(word)
    local keys = {}
    for _, cp in utf8.codes(word) do
        if cp >= SBASE and cp < SBASE + SCOUNT then
            local s = cp - SBASE
            keys[#keys+1] = CHO[math.floor(s / NCOUNT) + 1]
            for _, k in ipairs(JUNG_KEYS[math.floor((s % NCOUNT) / TCOUNT)]) do keys[#keys+1] = k end
            local t = s % TCOUNT
            if t > 0 then for _, k in ipairs(JONG_KEYS[t]) do keys[#keys+1] = k end end
        else keys[#keys+1] = cp end
    end
    return keys
end

local function render(committed, cho, jung, jong)
    if cho and jung then return committed .. utf8.char(SBASE + (cho*VCOUNT + jung)*TCOUNT + jong)
    elseif cho then return committed .. utf8.char(CHO[cho+1])
    elseif jung then return committed .. utf8.char(JUNG[jung+1]) end
    return committed
end

local function buildTypeStates(word)
    local keys = wordToKeys(word)
    local states, committed = {}, ""
    local cho, jung, jong = nil, nil, 0
    local function commit() committed = render(committed, cho, jung, jong); cho, jung, jong = nil, nil, 0 end
    for _, cp in ipairs(keys) do
        if CHO_OF[cp] then
            if cho and jung then
                if jong == 0 and JONG_OF[cp] then jong = JONG_OF[cp]
                elseif jong > 0 and JONG_COMBINE[jong*100 + cp] then jong = JONG_COMBINE[jong*100 + cp]
                else commit(); cho = CHO_OF[cp] end
            elseif cho then commit(); cho = CHO_OF[cp]
            else cho = CHO_OF[cp] end
        elseif JUNG_OF[cp] then
            if jong > 0 then
                local kt = JONG_KEYS[jong]
                if #kt == 2 then jong = JONG_OF[kt[1]]; commit(); cho = CHO_OF[kt[2]]; jung = JUNG_OF[cp]
                else jong = 0; commit(); cho = CHO_OF[kt[1]]; jung = JUNG_OF[cp] end
            elseif cho and jung then
                local comb = JUNG_COMBINE[jung*1000 + cp]
                if comb then jung = comb else commit(); jung = JUNG_OF[cp] end
            elseif jung then
                local comb = JUNG_COMBINE[jung*1000 + cp]
                if comb then jung = comb else commit(); jung = JUNG_OF[cp] end
            else jung = JUNG_OF[cp] end
        else commit(); committed = committed .. utf8.char(cp) end
        states[#states+1] = render(committed, cho, jung, jong)
    end
    local out = {}
    for _, s in ipairs(states) do if out[#out] ~= s then out[#out+1] = s end end
    if #out == 0 or out[#out] ~= word then out[#out+1] = word end
    return out
end

local requestFunction
do
    local tbl = {
        function() return request end,
        function() return http_request end,
        function() return http and http.request or nil end,
        function() local ok, r = pcall(function() return syn.request end) return ok and r or nil end,
        function() local ok, r = pcall(function() return Fluxus and Fluxus.request or nil end) return ok and r or nil end
    }
    for _, fn in pairs(tbl) do
        local ok, r = pcall(fn)
        if ok and r then requestFunction = r break end
    end
end

local function downloadData(url)
    if not requestFunction then return nil end
    local success, response = pcall(requestFunction, {Url = url, Method = "GET"})
    if success and response.StatusCode == 200 then return response.Body end
    return nil
end

local function initDataSystem()
    if readfile and isfile and isfile(DUEUM_CACHE) then
        pcall(function() DUEUM = HS:JSONDecode(readfile(DUEUM_CACHE)) end)
    else
        local rawDueum = downloadData(DUEUM_URL)
        if rawDueum then
            pcall(function() DUEUM = HS:JSONDecode(rawDueum) if writefile then writefile(DUEUM_CACHE, rawDueum) end end)
        end
    end
    if readfile and isfile and isfile(CACHE_FILE) then
        pcall(function() DICT = HS:JSONDecode(readfile(CACHE_FILE)) end)
    else
        local rawDict = downloadData(DICT_URL)
        if rawDict then
            pcall(function() DICT = HS:JSONDecode(rawDict) if writefile then writefile(CACHE_FILE, rawDict) end end)
        end
