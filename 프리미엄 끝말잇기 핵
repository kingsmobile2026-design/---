                        lbl.Text = " 🛡️ [방어] " .. w
                        lbl.TextColor3 = Color3.fromRGB(130, 255, 170)
                        lbl.LayoutOrder = 3
                    end
                    lbl.MouseButton1Click:Connect(function() sendWordToGame(w) end)
                end
                break
            end
        end
    end

    for _, target in ipairs(targets) do
        if DICT and DICT[target] then
            for _, w in ipairs(DICT[target]) do
