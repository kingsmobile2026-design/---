local function updateView(key)
    for _, c in ipairs(scroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
    if key == "" then return 0 end
    local targets = getCompatibleChars(key)
    local uniqueCheck = {}
    local resultCount = 0

    for _, w in ipairs(WordDB) do
        for _, target in ipairs(targets) do
            if string.sub(w, 1, string.len(target)) == target then
                if not uniqueCheck[w] then
                    uniqueCheck[w] = true
                    resultCount = resultCount + 1
                    local lbl = Instance.new("TextButton", scroll)
                    lbl.Size = UDim2.new(1, -4, 0, 22) 
                    lbl.Font = Enum.Font.SourceSansBold
