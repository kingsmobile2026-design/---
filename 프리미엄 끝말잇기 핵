local function checkIsKillWord(word)
    if word == "" then return false end
    
    local lastChar = string.sub(word, utf8.offset(word, utf8.len(word)))
    
    if EndingKillLetters[lastChar] then return true end
    
    local code = utf8.codepoint(lastChar)
    if code >= 0xAC00 and code <= 0xD7A3 then
        local hangulIndex = code - 0xAC00
        
        local jongsei = hangulIndex % 28
        local jungseong = math.floor((hangulIndex % 588) / 28)
        local choseong = math.floor(hangulIndex / 588)
        
        if DoubleJongseiIndex[jongsei] or TargetJongseiIndex[jongsei] then
            return true
        end
        
        if jungseong == 13 or jungseong == 9 then
            return true
        end
        
        if jungseong == 6 and AllowedYeoChoseong[choseong] then
            return true
        end
        
        if jungseong == 2 and AllowedYaChoseong[choseong] then
            return true
        end
    end
    
    return false
end

