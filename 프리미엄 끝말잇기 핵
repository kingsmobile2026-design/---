local function checkIsKillWord(word)
    if word == "" then return false end
    local successOffset, offset = pcall(function() return utf8.offset(word, utf8.len(word)) end)
    if not successOffset or not offset then return false end
    local lastChar = string.sub(word, offset)
    if EndingKillLetters[lastChar] or CustomKillLetters[lastChar] then return true end
    local code = utf8.codepoint(lastChar)
    if code >= 0xAC00 and code <= 0xD7A3 then
        local hangulIndex = code - 0xAC00
        local jongsei = hangulIndex % 28
        local jungseong = math.floor((hangulIndex % 588) / 28)
        local choseong = math.floor(hangulIndex / 588)
        if DoubleChoseongIndex[choseong] and jongsei > 0 then return true end
        if DoubleJongseiIndex[jongsei] or TargetJongseiIndex[jongsei] then return true end
        if jungseong == 13 or jungseong == 9 then return true end
        if jungseong == 6 and AllowedYeoChoseong[choseong] then return true end
        if jungseong == 2 and AllowedYaChoseong[choseong] then return true end
    end
    return false
end

local function checkIsChobanWord(word)
    if word == "" then return false end
    local successOffset, offset = pcall(function() return utf8.offset(word, utf8.len(word)) end)
    if not successOffset or not offset then return false end
    local lastChar = string.sub(word, offset)
    return ChobanEndingLetters[lastChar] or false
end

