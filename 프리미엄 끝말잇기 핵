local requestFunction
do
    local tbl = {
        function() return request end,
        function() return http_request end,
        function() return http and http.request or nil end,
        function() local ok, r = pcall(function() return syn.request end) return ok and r or nil end,
    }
    for _, fn in pairs(tbl) do
        local ok, r = pcall(fn)
        if ok and r then requestFunction = r break end
    end
end

local function downloadData(url)
    if not requestFunction then return nil end
    local success, response = pcall(requestFunction, {Url = url, Method = "GET"})
    if success and response.StatusCode == 200 then
        return response.Body
    end
    return nil
end

local function initDataSystem()
    if readfile and isfile and isfile(DUEUM_CACHE) then
        pcall(function() DUEUM = HS:JSONDecode(readfile(DUEUM_CACHE)) end)
    else
        local rawDueum = downloadData(DUEUM_URL)
        if rawDueum then
            pcall(function() 
                DUEUM = HS:JSONDecode(rawDueum)
                if writefile then writefile(DUEUM_CACHE, rawDueum) end
            end)
        end
    end

    if readfile and isfile and isfile(CACHE_FILE) then
        pcall(function() DICT = HS:JSONDecode(readfile(CACHE_FILE)) end)
    else
        local rawDict = downloadData(DICT_URL)
        if rawDict then
            pcall(function() 
                DICT = HS:JSONDecode(rawDict)
                if writefile then writefile(CACHE_FILE, rawDict) end
            end)
        end
    end
end
initDataSystem()

local function getCompatibleChars(char)
    if DUEUM and DUEUM[char] then
        if type(DUEUM[char]) == "table" then
            local res = {char}
            for _, v in ipairs(DUEUM[char]) do table.insert(res, v) end
            return res
        else
            return {char, DUEUM[char]}
        end
    end
    return {char}
end

